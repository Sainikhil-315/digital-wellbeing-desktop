{
  "name": "digital-wellbeing",
  "version": "1.0.0",
  "description": "Desktop screen time tracker and focus tool",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always",
    "electron": "electron .",
    "vite": "vite",
    "postinstall": "node scripts/copy-wasm.js"
  },
  "dependencies": {
    "sql.js": "^1.11.0",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.digitalwellbeing.app",
    "productName": "Digital Wellbeing",
    "directories": { "output": "dist-electron" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": ["dist/**/*", "electron/**/*", "assets/**/*"],
    "publish": {
      "provider": "github",
      "owner": "Sainikhil-315",
      "repo": "digital-wellbeing-desktop"
    }
  }
}